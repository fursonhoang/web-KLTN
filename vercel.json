{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/css/(.*)",
      "destination": "/css/$1"
    },
    {
      "source": "/js/(.*)",
      "destination": "/js/$1"
    },
    {
      "source": "/assets/(.*)",
      "destination": "/assets/$1"
    },
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "(.*)-admin.?"
        }
      ],
      "destination": "/admin/admin-dashboard.html"
    },
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "(.*)-employer.?"
        }
      ],
      "destination": "/employer-dashboard.html"
    },
    {
      "source": "/((?!admin|css|js|assets).*)",
      "has": [
        {
          "type": "host",
          "value": "(.*)-admin.?"
        }
      ],
      "destination": "/admin/$1"
    }
  ]
}
